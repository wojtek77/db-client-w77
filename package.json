{
  "name": "db-client-w77",
  "displayName": "MariaDB & MySQL Database Client",
  "description": "High-performance MariaDB and MySQL client for VS Code. Enjoy schema suggestions, SQL autocomplete, data editing, and quick query formatting.",
  "publisher": "W77",
  "version": "0.1.17",
  "icon": "DB-client.png",
  "engines": {
    "vscode": "^1.118.0"
  },
  "repository": {
    "url": "https://github.com/wojtek77/db-client-w77"
  },
  "bugs": {
    "url": "https://github.com/wojtek77/db-client-w77/issues"
  },
  "categories": [
    "Other",
    "Data Science"
  ],
  "keywords": [
    "database-client",
    "mariadb",
    "mysql",
    "sql-client",
    "query-runner",
    "sql",
    "database",
    "db"
  ],
  "activationEvents": [
    "onLanguage:sql"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "grammars": [
      {
        "scopeName": "comment.injection.sql.hash",
        "path": "./syntaxes/sql-hash-comment.tmLanguage.json",
        "injectTo": [
          "source.sql"
        ]
      }
    ],
    "viewsContainers": {
      "panel": [
        {
          "id": "sqlResults",
          "title": "SQL",
          "icon": "$(database)",
          "when": "dbClientActive"
        }
      ]
    },
    "views": {
      "sqlResults": [
        {
          "icon": "DB-client.png",
          "type": "webview",
          "id": "sqlResultsView",
          "name": "Wyniki SQL",
          "when": "dbClientActive"
        }
      ]
    },
    "commands": [
      {
        "command": "db-client.runSQL",
        "title": "DB client: Run SQL"
      },
      {
        "command": "db-client.runSqlWholeFile",
        "title": "DB client: Run SQL Whole File"
      },
      {
        "command": "db-client.openRecentFiles",
        "title": "DB client: Open Recent SQL Files"
      },
      {
        "command": "db-client.formatSQL",
        "title": "DB client: Format SQL"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "db-client.runSQL",
          "when": "resourceExtname == '.sql'",
          "group": "1_modification"
        },
        {
          "command": "db-client.runSqlWholeFile",
          "when": "resourceExtname == '.sql'",
          "group": "1_modification"
        },
        {
          "command": "db-client.formatSQL",
          "when": "resourceExtname == '.sql' && editorHasSelection",
          "group": "1_modification"
        }
      ]
    },
    "keybindings": [
      {
        "command": "db-client.runSqlWholeFile",
        "key": "alt+x",
        "when": "editorTextFocus && !editorReadonly && resourceExtname == '.sql'"
      },
      {
        "command": "db-client.runSQL",
        "key": "ctrl+enter",
        "when": "editorTextFocus && !editorReadonly && resourceExtname == '.sql'"
      },
      {
        "command": "db-client.openRecentFiles",
        "key": "F3"
      },
      {
        "command": "db-client.formatSQL",
        "key": "ctrl+shift+f",
        "when": "editorTextFocus && !editorReadonly && resourceExtname == '.sql' && editorHasSelection"
      }
    ],
    "configuration": {
      "title": "DB Client",
      "properties": {
        "db-client.dbConfigsDir": {
          "type": "string",
          "default": "",
          "scope": "resource",
          "markdownDescription": "Absolute path to the directory where database connection configurations are stored. Leave empty to use the default `.db_configs` directory in the user's home directory. Note: The path must not end with a slash (/) or backslash (\\\\)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.118.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "typescript-eslint": "^8.61.1",
    "eslint": "^10.5.0",
    "esbuild": "^0.28.1",
    "npm-run-all": "^4.1.5",
    "typescript": "^6.0.3",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0"
  },
  "dependencies": {
    "mariadb": "^3.5.2"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  }
}
