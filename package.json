{
  "name": "db-client-w77",
  "displayName": "db-client-w77",
  "description": "DB client",
  "version": "0.0.1",
  "icon": "git.png",
  "engines": {
    "vscode": "^1.118.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "panel": [
        {
          "id": "sqlResults",
          "title": "SQL",
          "icon": "$(database)",
          "when": "dbClientActive"
        }
      ]
    },
    "views": {
      "sqlResults": [
        {
          "icon": "git.png",
          "type": "webview",
          "id": "sqlResultsView",
          "name": "Wyniki SQL",
          "when": "dbClientActive"
        }
      ]
    },
    "commands": [
      {
        "command": "db-client.executeSQL",
        "title": "Wykonaj SQL z edytora"
      },
      {
        "command": "db-client.openPanel",
        "title": "Otwórz panel wyników SQL"
      }
    ],
    "keybindings": [
      {
        "command": "db-client.executeSQL",
        "key": "ctrl+enter",
        "when": "editorTextFocus && !editorReadonly && resourceExtname == '.sql'"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/ini": "^4.1.1",
    "@types/jest": "^30.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.18",
    "@types/vscode": "^1.118.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "ini": "^6.0.0",
    "mariadb": "^3.5.2"
  }
}